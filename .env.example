# --- Environment: development | production ---
ENVIRONMENT=development

# --- Database (REQUIRED) — Supabase Postgres connection string ---
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# --- CORS: comma-separated list of allowed frontend origins ---
CORS_ORIGINS=http://localhost:3000

# --- Clerk auth (optional until the auth module) ---
CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET: Clerk Dashboard → Webhooks → endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=

# --- Supabase Storage (service role key — server-side ONLY, never expose) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Telegram notifications (D9, optional: leave empty to disable) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Frontend base URL (used to build the event link in Telegram messages) ---
WEBSITE_URL=https://los-inmaduros-rollers.vercel.app